# ============ SUPABASE (REQUIRED) ============
# Get from: https://supabase.com → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key

# ============ JWT Security (REQUIRED) ============
# Generate a random 32+ character string
# You can use: openssl rand -hex 32
SECRET_KEY=your-super-secret-jwt-key-minimum-32-characters-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============ WHATSAPP (OPTIONAL) ============
# Get from: https://fonnte.com (Indonesia) or Twilio (International)
# Leave empty for mock mode (logs to console)
WHATSAPP_API_KEY=
WHATSAPP_API_URL=

# ============ EMAIL (OPTIONAL) ============
# Get from: https://sendgrid.com → Settings → API Keys
# Leave empty for mock mode (logs to console)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@amanga.id
SENDGRID_FROM_NAME=Aman ga?
